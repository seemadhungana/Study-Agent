# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# AWS credentials for local development (not needed on Lambda — it uses the execution role)
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_DEFAULT_REGION=us-east-1

# Optional: override the Bedrock model ID (default: Claude Haiku)
LLM_MODEL=anthropic.claude-haiku-4-5-20251001-v1:0

# Optional: DynamoDB table name (default: StudyAssistantSessions)
CHAT_HISTORY_TABLE_NAME=StudyAssistantSessions

# S3 bucket for the ChromaDB vector knowledge base (set after first SAM deploy)
# Get this from: aws cloudformation describe-stacks --stack-name study-assistant --query "Stacks[0].Outputs"
KNOWLEDGE_BUCKET=study-assistant-knowledge-<your-account-id>
